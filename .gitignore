__pycache__/
.DS_Store
.env
node_modules/
.next/
venv/
.venv/

# Runtime data (local only)
run_history.db
job_history.json
output/
prompt_writer_settings.json

# Flow data (gitignored, personal pipelines)
flows/*.flow.json

# Private block overlay (local-only blocks that never enter the public OSS build)
private_blocks/
# Codegen output for private blocks (regenerated on every `npm run predev`)
frontend/src/components/pipeline/custom_blocks/generated_private/
# _register.ts is auto-generated AND its import set depends on whether
# private_blocks/ exists on the current machine. Committing it caused fresh
# checkouts to fail with "Module not found: ./generated_private/<slug>" when
# codegen hadn't populated those files yet.
frontend/src/components/pipeline/custom_blocks/_register.ts

# Dev artifacts (root-level scratch docs, not the public docs/architecture.md)
/architecture.md
frontend/architecture.md
issues.md
frontend/issues.md
logs.txt

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Screenshots & runtime caches
BlockFlow_ScreenCapture/
comfy_gen_info_cache.json

# Agent worktrees
.claude/worktrees/
