# ---- Required ----
RUNPOD_API_KEY=rpa_...
OPENROUTER_API_KEY=sk-or-v1-...

# ---- Optional: RunPod Endpoint Override ----
# Only set this if you want to override the endpoint ID from comfy-gen config.
# RUNPOD_ENDPOINT_ID=

# ---- Optional Services ----
# TOPAZ_API_KEY=                      # Topaz Labs API key (for upscaling blocks)
# CIVITAI_API_KEY=                    # CivitAI API key (for sharing, advanced mode)
# IMGBB_API_KEY=                      # ImgBB API key (recommended for Dataset Create reference uploads)

# ---- Generation Defaults ----
# DEFAULT_WIDTH=832
# DEFAULT_HEIGHT=480
# DEFAULT_FRAMES=81                   # Must be 4n+1: 81, 121, 161...
# DEFAULT_FPS=16

# ---- Prompt Writer ----
# DEFAULT_WRITER_MODEL=               # OpenRouter model ID (leave empty for model picker)
# DEFAULT_WRITER_TEMPERATURE=0.6
# DEFAULT_WRITER_MAX_TOKENS=100000

# ---- Performance ----
# APP_MAX_PARALLEL_WORKERS=6          # Max concurrent generation jobs
# RUNPOD_POLL_INTERVAL_SEC=4          # Status polling interval (seconds)
# RUNPOD_POLL_TIMEOUT_SEC=2400        # Max wait time per job (seconds)
